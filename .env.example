# Voxis — Python client environment
# Copy this file to .env; the runtime writes VOXIS_JWT_TOKEN automatically after login.
# Only set the values you need to override; the defaults work for the SaaS build.

# JWT token issued by auth-core after login (auto-written by app/voxis_client.py).
VOXIS_JWT_TOKEN=

# Base URL of the auth-core service.
# Leave as-is for the official SaaS endpoint, or point to a self-hosted instance.
VOXIS_API_URL=https://voxislive.com

# Set to 1 to force the official-release build path (hides BYOK settings, forces
# the server-side Gemini key). Leave unset (or 0) for the open-source / BYOK build.
VOXIS_OFFICIAL_RELEASE=0
