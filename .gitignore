# --- Voxis Production Git Ignore ---

# --- Runtime secrets & tokens ---
.env
.env.local
.env.*.local
config.json
config.json._pending_default_restore
# Runtime artifacts a source run drops in the repo root (from source the
# user-data dir resolves to the repo root; see app/paths.py). Never publish.
jwt.dat
*.dat
install.secret
legacy_machine.secret
*.secret
voxis.log

# --- Proprietary / closed-source ---
# Open-core premium add-ons
premium/
# Server-side auth service — self-host deployers maintain a private fork
backend/
# Marketing site — deployed separately to the server, not part of the public repo
website/
# Microsoft Store listing copy (official-product marketing — kept private, like website/)
store-listings/
# Offline dubbing product — separate commercial tool, planning + future source (private)
voxis-dubber/
# Browser (Chromium/Edge MV3) extension — closed-core SaaS product, never public
extension/
# Server-side anti-abuse strategy/specs — kept private (lives on the host, not public)
docs/server/
# End-user (SaaS) install guide — published on voxislive.com, not in the OSS repo
docs/INSTALL_SAAS.md
# Marketing / growth / backlink strategy — competitive intel, kept private
docs/marketing/

# --- Per-user runtime data ---
# DPAPI-wrapped BYOK key slots (CURRENT_USER + per-install entropy; useless cross-machine)
profiles/

# --- Python artefacts ---
__pycache__/
*.pyc
.venv/
venv/
build/
dist/
*.egg-info/

# --- Flutter / Dart artefacts ---
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies

# --- Packaged release output (built by app/build_official.py; too large for git) ---
production_release/
# Microsoft VC++ redistributable, fetched at build time by build_official.py (not vendored)
installer/redist/

# --- Session output ---
transcripts/
obs_subtitle.txt

# --- OS noise ---
.DS_Store
Thumbs.db

# --- AI session memory (stays local) ---
.claude/
# Third-party Agent Skills installed via `npx skills add` (universal copies + lockfile) — not part of the OSS engine
.agents/
skills-lock.json

# --- Internal strategy/roadmap (private planning — never publish) ---
ROADMAP.md
STRATEGY_REPORT.md
# Consolidated private planning vault (master plan, dead-code report, launch kit,
# brand assets). Competitive intel + server specs — never publish.
PLAN/

# --- SQLite WAL fragments ---
*.db-shm
*.db-wal

# --- Benchmark fixtures (regenerate via fetch_fleurs.py) + run outputs ---
scripts/bench/fixtures/**/*.wav
scripts/bench/results*.jsonl

# --- Local-only working notes + dev launch helper (never ship / publish) ---
next.md
docs/mail.md
start-official.bat

# --- Throwaway experiment: OpenAI Realtime translate sandbox (never ship) ---
sandbox-openai-realtime/

# --- Throwaway experiment: Qwen LiveTranslate realtime sandbox (never ship) ---
sandbox-qwen-livetranslate/

# --- Private brand asset kit (icons, favicons, lockups, OG/social) — moved in from Desktop 2026-07-05 ---
brand-set/

# --- Private working notes (outreach, responses, pricing plans) — moved in from Desktop 2026-07-05 ---
notes/
# Local ops dashboard (gitignored — carries host IP, business data, secrets)
panel/
